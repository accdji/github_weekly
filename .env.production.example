# PostgreSQL production database URL
DATABASE_URL="postgresql://postgres:password@host:5432/open_source_trend?sslmode=require"

# GitHub API token for search, repository detail, and stargazer history sync
GITHUB_TOKEN=""

# Optional custom repository search query. Leave empty to use the built-in default query.
GITHUB_SEARCH_QUERY=""

# Comma-separated languages used by the discovery pipeline
GITHUB_TOP_LANGUAGES="TypeScript,JavaScript,Python,Go,Rust"

# Repository count fetched per query
COLLECT_PER_QUERY="20"

# Stargazer history backfill window
GITHUB_STAR_HISTORY_DAYS="35"

# Maximum GitHub pagination pages used for star history backfill
GITHUB_STAR_HISTORY_MAX_PAGES="20"

# Job trigger marker shown in task records
JOB_TRIGGERED_BY="github-actions"
